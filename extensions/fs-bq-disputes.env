LOCATION=us-central1
DATASET_LOCATION=us
BIGQUERY_PROJECT_ID=meraki-salon-manager
DATABASE=(default)
DATABASE_REGION=nam5
COLLECTION_PATH=tenants/{tenantId}/disputes
WILDCARD_IDS=true
DATASET_ID=firestore_export
TABLE_ID=disputes
TABLE_PARTITIONING=NONE
VIEW_TYPE=view
USE_NEW_SNAPSHOT_QUERY_SYNTAX=yes
EXCLUDE_OLD_DATA=no
LOG_LEVEL=info
