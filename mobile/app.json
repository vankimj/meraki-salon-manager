{
  "expo": {
    "name": "Plume Nexus",
    "slug": "meraki-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "plumenexus",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f1923"
    },
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#2D7A5F",
      "iosDisplayInForeground": true
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.plumenexus.pro",
      "entitlements": {
        "com.apple.developer.proximity-reader.payment.acceptance": true
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.563347750501-n1pe3i700s6fh75cpu1sspjjd63n04oa"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f1923"
      },
      "package": "app.plumenexus.pro",
      "useNextNotificationsApi": true
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          },
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2D7A5F"
        }
      ],
      "expo-asset",
      "expo-web-browser",
      "@react-native-google-signin/google-signin",
      "@react-native-community/datetimepicker",
      [
        "@stripe/stripe-terminal-react-native",
        {
          "bluetoothBackgroundMode": true,
          "locationWhenInUsePermission": "Location is used to accept in-person card payments.",
          "bluetoothPeripheralPermission": "Bluetooth is used to connect to a card reader.",
          "bluetoothAlwaysUsagePermission": "Bluetooth is used to connect to a card reader."
        }
      ],
      "expo-audio"
    ],
    "extra": {
      "eas": {
        "projectId": "9da1f1fe-ab09-4f73-9367-0c67232234cc"
      }
    },
    "owner": "jvankim",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/9da1f1fe-ab09-4f73-9367-0c67232234cc"
    }
  }
}
