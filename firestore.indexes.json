{
  "// indexes": "Composite indexes Firestore can't derive automatically. Auto-discovered missing ones fail at query time with FAILED_PRECONDITION: ...create_composite=... — copy that URL into a comment and add an entry here so it deploys via firebase deploy --only firestore:indexes instead of getting created ad-hoc in Console.",
  "indexes": [
    {
      "//": "purgeOldTombstones cron — needs (_deleted == true) AND (_deletedAt < cutoff) per soft-deleted customer-data collection",
      "collectionGroup": "clients",         "queryScope": "COLLECTION", "fields": [{"fieldPath": "_deleted", "order": "ASCENDING"}, {"fieldPath": "_deletedAt", "order": "ASCENDING"}]
    },
    {"collectionGroup": "appointments",     "queryScope": "COLLECTION", "fields": [{"fieldPath": "_deleted", "order": "ASCENDING"}, {"fieldPath": "_deletedAt", "order": "ASCENDING"}]},
    {"collectionGroup": "receipts",         "queryScope": "COLLECTION", "fields": [{"fieldPath": "_deleted", "order": "ASCENDING"}, {"fieldPath": "_deletedAt", "order": "ASCENDING"}]},
    {"collectionGroup": "memberships",      "queryScope": "COLLECTION", "fields": [{"fieldPath": "_deleted", "order": "ASCENDING"}, {"fieldPath": "_deletedAt", "order": "ASCENDING"}]},
    {"collectionGroup": "giftCards",        "queryScope": "COLLECTION", "fields": [{"fieldPath": "_deleted", "order": "ASCENDING"}, {"fieldPath": "_deletedAt", "order": "ASCENDING"}]},
    {"collectionGroup": "services",         "queryScope": "COLLECTION", "fields": [{"fieldPath": "_deleted", "order": "ASCENDING"}, {"fieldPath": "_deletedAt", "order": "ASCENDING"}]},
    {"collectionGroup": "employees",        "queryScope": "COLLECTION", "fields": [{"fieldPath": "_deleted", "order": "ASCENDING"}, {"fieldPath": "_deletedAt", "order": "ASCENDING"}]},
    {"collectionGroup": "bonuses",          "queryScope": "COLLECTION", "fields": [{"fieldPath": "_deleted", "order": "ASCENDING"}, {"fieldPath": "_deletedAt", "order": "ASCENDING"}]},
    {"collectionGroup": "membershipPlans",  "queryScope": "COLLECTION", "fields": [{"fieldPath": "_deleted", "order": "ASCENDING"}, {"fieldPath": "_deletedAt", "order": "ASCENDING"}]},
    {"collectionGroup": "timeOff",          "queryScope": "COLLECTION", "fields": [{"fieldPath": "_deleted", "order": "ASCENDING"}, {"fieldPath": "_deletedAt", "order": "ASCENDING"}]},
    {"collectionGroup": "promoCodes",       "queryScope": "COLLECTION", "fields": [{"fieldPath": "_deleted", "order": "ASCENDING"}, {"fieldPath": "_deletedAt", "order": "ASCENDING"}]},
    {"collectionGroup": "reviews",          "queryScope": "COLLECTION", "fields": [{"fieldPath": "_deleted", "order": "ASCENDING"}, {"fieldPath": "_deletedAt", "order": "ASCENDING"}]},
    {"collectionGroup": "meetings",         "queryScope": "COLLECTION", "fields": [{"fieldPath": "_deleted", "order": "ASCENDING"}, {"fieldPath": "_deletedAt", "order": "ASCENDING"}]},
    {"collectionGroup": "products",         "queryScope": "COLLECTION", "fields": [{"fieldPath": "_deleted", "order": "ASCENDING"}, {"fieldPath": "_deletedAt", "order": "ASCENDING"}]},
    {"collectionGroup": "campaigns",        "queryScope": "COLLECTION", "fields": [{"fieldPath": "_deleted", "order": "ASCENDING"}, {"fieldPath": "_deletedAt", "order": "ASCENDING"}]},

    {
      "//": "subscribeQueue / fetchTodayQueue — walk-in waitlist filtered by date and ordered by addedAt. Required for the Schedule's queue panel + ModuleShell badge. Missing this caused the first crash on the test tenant subdomain (which had never had a waitlist doc to seed the auto-index).",
      "collectionGroup": "waitlist",         "queryScope": "COLLECTION", "fields": [{"fieldPath": "date", "order": "ASCENDING"}, {"fieldPath": "addedAt", "order": "ASCENDING"}]
    },

    {
      "//": "Service ratings — list per tech ordered by submittedAt (Reports → ratings tab + leaderboard). Composite required because where(techName) + orderBy(submittedAt) can't use auto-index.",
      "collectionGroup": "serviceRatings",   "queryScope": "COLLECTION", "fields": [{"fieldPath": "techName", "order": "ASCENDING"}, {"fieldPath": "submittedAt", "order": "DESCENDING"}]
    },

    {
      "//": "listOpenSupportTickets — cross-tenant queue at admin.plumenexus.com/tickets uses collectionGroup('supportTickets') with where(status==X).orderBy(lastReplyAt desc). Composite CG index required.",
      "collectionGroup": "supportTickets", "queryScope": "COLLECTION_GROUP",
      "fields": [
        {"fieldPath": "status",      "order": "ASCENDING"},
        {"fieldPath": "lastReplyAt", "order": "DESCENDING"}
      ]
    }
  ],
  "fieldOverrides": [
    {
      "//": "getReceiptByToken — single-field equality on viewToken across the receipts collection group. Single-field CG queries need fieldOverrides (not a composite); Firestore rejects the composite form with 'this index is not necessary'.",
      "collectionGroup": "receipts",
      "fieldPath":       "viewToken",
      "indexes": [
        {"order": "ASCENDING", "queryScope": "COLLECTION_GROUP"}
      ]
    },
    {
      "//": "listOpenSupportTickets — 'all' status path drops the where() and just orderBy(lastReplyAt desc) on the supportTickets collection group. Single-field CG → fieldOverrides.",
      "collectionGroup": "supportTickets",
      "fieldPath":       "lastReplyAt",
      "indexes": [
        {"order": "DESCENDING", "queryScope": "COLLECTION_GROUP"}
      ]
    }
  ]
}
