rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isBootstrapAdmin() {
      return request.auth != null &&
             request.auth.token.email in ['jvankim@gmail.com'];
    }
    function isAuthenticated() {
      return request.auth != null;
    }
    // Tenant owner: email matches the ownerEmail stored in the root tenant registry doc.
    function isTenantOwner(tenantId) {
      return isAuthenticated() &&
        request.auth.token.email ==
          get(/databases/$(database)/documents/tenants/$(tenantId)).data.ownerEmail;
    }
    // Tenant admin: the tenant's ownerEmail, OR any user whose role is
    // 'admin' in the tenant's data/users doc (mirrored into `adminEmails`
    // by saveUsers).
    //
    // PRINCIPLE #10: bootstrap admin (the platform founder) is intentionally
    // NOT in this list. Founder access is by invitation only — to access a
    // tenant's data, the founder must be added to that tenant's users array
    // via the salon app's normal Admin → Users flow, exactly like adding any
    // staff member. The Meraki tenant already lists jvankim@gmail.com via
    // this mechanism, so Meraki access works unchanged.
    function isTenantAdmin(tenantId) {
      return isTenantOwner(tenantId) || (
        isAuthenticated() &&
        request.auth.token.email is string &&
        request.auth.token.email.lower() in
          get(/databases/$(database)/documents/tenants/$(tenantId)/data/users)
            .data.get('adminEmails', [])
      );
    }
    // Tenant staff: caller's email is in this tenant's `data/users` doc's
    // `staffEmails` array (maintained by saveUsers — every email whose role
    // is admin/readonly/tech/scheduler ends up here; pending/denied users
    // are excluded). This is the primary tenant-scoped authorization for
    // staff operations and closes the cross-tenant data-access vector
    // where any signed-in user could read/write any tenant's data.
    function isTenantStaff(tenantId) {
      return isTenantAdmin(tenantId) || (
        isAuthenticated() &&
        request.auth.token.email is string &&
        request.auth.token.email.lower() in
          get(/databases/$(database)/documents/tenants/$(tenantId)/data/users)
            .data.get('staffEmails', [])
      );
    }
    // A tech explicitly set to view-only schedule access (Admin → Users).
    // Maintained by saveUsers as the `scheduleViewOnlyEmails` projection on
    // data/users. Admins/owners are never in this list.
    function isScheduleViewOnly(tenantId) {
      return isAuthenticated() &&
        request.auth.token.email is string &&
        request.auth.token.email.lower() in
          get(/databases/$(database)/documents/tenants/$(tenantId)/data/users)
            .data.get('scheduleViewOnlyEmails', []);
    }
    // Staff who may write appointments: any tenant staff EXCEPT a view-only
    // tech. Admins/owners always qualify (isTenantAdmin short-circuits via
    // isTenantStaff and admins are never in the view-only list).
    function canEditSchedule(tenantId) {
      return isTenantStaff(tenantId) && !isScheduleViewOnly(tenantId);
    }

    // ── Legacy path (read-only for migration) ────────────
    match /salon/{document} {
      allow read: if true;
      allow write: if isBootstrapAdmin();
    }
    match /logs/{logId} {
      allow read:   if isBootstrapAdmin();
      allow create: if isAuthenticated();
    }

    // ── OAuth state nonces (gustoGetAuthUrl mints them, gustoOAuthCallback
    //    verifies + deletes them). Server-side only — admin SDK in
    //    Cloud Functions bypasses rules; client SDK must never see these.
    //    Default-deny would already block this, but the explicit rule
    //    documents the intent and prevents a future broader rule from
    //    accidentally exposing them.
    match /_oauthNonces/{nonce} {
      allow read, write: if false;
    }

    // ── Public slug → tenant indirection ─────────────────
    //   Doc id = subdomain slug (lowercase). Doc body shape:
    //     { tenantId: string,
    //       kind:     'primary' | 'alias' | 'reserved',
    //       primarySlug?: string,    // when kind=='alias'
    //       createdAt: ISO date,
    //       reservedReason?: string  // when kind=='reserved'
    //     }
    //   Anyone (incl. unauthenticated visitors) can READ. Reading just
    //   tells you `<slug>.plumenexus.com` exists / is taken / redirects —
    //   no sensitive tenant data leaks because all of that lives in
    //   tenants/{tenantId} (locked to bootstrap admin) or tenants/.../data
    //   (locked to staff).
    //   WRITES only from bootstrap admin (manual platform-admin actions)
    //   or Cloud Functions via admin SDK (which bypasses rules). The
    //   `provisionTenant` orchestrator is the canonical creator.
    match /slugs/{slug} {
      allow read:  if true;
      allow write: if isBootstrapAdmin();
    }

    // ── Provisioning job state ───────────────────────────
    //   provisionTenant + deleteTenant write per-step progress here so
    //   the signup UI can poll and platform-admin can audit. Body shape:
    //     { jobId, slug, tenantId, plan, callerUid, ownerEmail, salonName,
    //       status:  'running' | 'succeeded' | 'failed',
    //       currentStep, failedStep?, error?,
    //       steps: { stepName: { ok, at, ... } },
    //       startedAt, completedAt?, updatedAt }
    //   Read: signed-in caller who started the job (callerUid match) OR
    //   bootstrap admin (platform-admin observability). Writes only from
    //   Cloud Functions via admin SDK.
    match /provisioningJobs/{jobId} {
      allow read:  if isBootstrapAdmin() ||
                   (isAuthenticated() && request.auth.uid ==
                      resource.data.get('callerUid', ''));
      allow write: if false;
    }

    // ── Per-phone tenant uniqueness ──────────────────────
    //   Doc id = the E.164 phone number (e.g. +15551234567).
    //   provisionTenant writes a claim atomically with slug reservation
    //   to prevent one verified phone from spinning up multiple Solo
    //   tenants (anti-abuse). Body: { tenantId, slug, ownerEmail, claimedAt }.
    //   Server-only — clients can't read or write. The Cloud Function
    //   provides the "is this phone taken?" check at provision time;
    //   exposing the collection to clients would leak phone numbers.
    match /phoneClaims/{phone} {
      allow read, write: if false;
    }

    // ── Platform-admin audit log ─────────────────────────
    //   Append-only forensic trail of all platform-admin actions.
    //   Body shape: { action, actor, actorUid, ip, userAgent, payload,
    //   at }. Write only via admin SDK (Cloud Functions); never from
    //   the client. Bootstrap admin can read (powers the audit-log
    //   view in admin.plumenexus.com).
    match /platformAuditLog/{id} {
      allow read:  if isBootstrapAdmin();
      allow write: if false;
    }

    // ── Client → salon routing index ─────────────────────
    //   `clientSalonIndex/{e164Phone}` → { tenantId, clientId, lastOutboundAt }.
    //   Cross-tenant lookup table populated by sendSms, used by
    //   twilioInboundSms when the inbound To is the shared Plume Nexus TFN
    //   (we need to know which salon most recently messaged this client
    //   to route their reply to the right tenant's chat thread).
    //   Server-only — exposing it would leak which salon's clients have
    //   which phone numbers, across tenants.
    match /clientSalonIndex/{phone} {
      allow read, write: if false;
    }

    // ── Inbound SMS orphan triage queue ──────────────────
    //   `platform/inboundOrphans/queue/{id}` → { from, to, body, twilioSid, at }.
    //   Populated by twilioInboundSms when a message arrives on the shared
    //   Plume Nexus TFN from a phone we have no client→salon mapping for.
    //   Bootstrap admin can read for the platform-admin SMS triage view;
    //   all writes happen via admin SDK (twilioInboundSms write, the
    //   forwardInboundOrphan / deleteInboundOrphan callables delete).
    match /platform/inboundOrphans/queue/{id} {
      allow read:  if isBootstrapAdmin();
      allow write: if false;
    }

    // ── Tenant data ──────────────────────────────────────
    match /tenants/{tenantId} {
      // Root tenant registry document. Holds plan, billing, owner contact,
      // subdomain, aliases, sandboxMode + other tenant-wide flags.
      // - Tenant admins of THIS tenant can read it (their own salon's
      //   metadata; banner UI + plan-gate reads depend on this).
      // - Writes still restricted to platform admins / Cloud Functions —
      //   we don't want tenant admins flipping their own sandboxMode or
      //   plan field from the client. setTenantSandboxMode (callable)
      //   is the gated path for that.
      allow read:  if isBootstrapAdmin() || isTenantAdmin(tenantId);
      allow write: if isBootstrapAdmin();

      // Config documents live in a data/ sub-collection (4-segment paths = valid Firestore docs)
      match /data/slides {
        allow read:  if true;
        allow write: if isTenantAdmin(tenantId);
      }
      // Front-desk kiosk checkout session. A tech "sends to front desk" (write);
      // the kiosk iPad subscribes (read); both ends update/clear it. Both are
      // staff devices and it holds only the in-flight cart + client name —
      // nothing sensitive (no card data; charges run through Cloud Functions).
      match /data/checkoutSession {
        allow read, write: if isTenantStaff(tenantId);
      }
      // Slim user projections — staff readable. Holds ONLY:
      //   staffEmails  (array of every staff email; rules use this for
      //                  isTenantStaff() membership checks)
      //   adminEmails  (array of admin emails; rules use it for
      //                  isTenantAdmin() and admin-notification fanout)
      //   byEmail      (map of email -> { role, techName? }; lets a
      //                  staff member look up their OWN role without
      //                  seeing coworkers' names / pictures / addedAt)
      // The rich users[] array (with names, photos, addedAt, etc.) lives
      // in data/usersFull below, admin-only.
      match /data/users {
        allow read:  if isTenantStaff(tenantId);
        allow write: if isTenantAdmin(tenantId);
      }
      // Rich user records — admin-only. A staff member cannot
      // enumerate every coworker's name + photo + techName + role +
      // grantedAt timestamp from the JS console.
      match /data/usersFull {
        allow read, write: if isTenantAdmin(tenantId);
      }
      match /data/settings {
        allow read:  if isTenantStaff(tenantId);
        allow write: if isTenantAdmin(tenantId);
      }
      // Sensitive credentials (OAuth tokens, third-party API keys cached
      // at runtime, anything that grants out-of-band access). Admin-only
      // read so a non-admin tenant staff member can't pull stored Gusto
      // / Stripe / Twilio credentials from the JS console.
      match /data/settingsPrivate {
        allow read, write: if isTenantAdmin(tenantId);
      }
      match /data/handbook {
        allow read:  if isTenantStaff(tenantId);
        allow write: if isTenantAdmin(tenantId);
      }
      match /data/bookingConfig {
        allow read:  if true;
        allow write: if isTenantAdmin(tenantId);
      }
      match /data/webfront {
        allow read:  if true;
        allow write: if isTenantAdmin(tenantId);
      }
      match /data/googleReviews {
        allow read:  if true;
        allow write: if isTenantAdmin(tenantId);
      }
      // Local competitor ranking — Google Places snapshot of nearby nail
      // salons. Read: tenant admin (Marketing → Local Ranking tab). Write:
      // server-only via nearbyNailSalons Cloud Function (admin SDK).
      match /data/competitorRankings {
        allow read:  if isTenantAdmin(tenantId);
        allow write: if false;
      }
      // Google Business Profile OAuth state. Holds the KMS-encrypted refresh
      // token + the resolved accountId / locationId path. Admin-readable so
      // the UI can show connect status; server-only writes — the
      // googleBusinessAuthCallback / sync functions write via Admin SDK.
      match /data/googleBusinessAuth {
        allow read:  if isTenantAdmin(tenantId);
        allow write: if false;
      }
      // Pending OAuth state tokens (CSRF defense). Server-only.
      match /data/googleBusinessAuthState {
        allow read, write: if false;
      }
      // Full public review history pulled from Google Business Profile API.
      // Each doc is one review keyed by Google's review name. Admin-readable
      // for the Public Reviews panel; server-only writes via the sync CF.
      match /googleReviewsLog/{reviewId} {
        allow read:  if isTenantAdmin(tenantId);
        allow write: if false;
      }
      // Demo-seed checkpoint for the resumable seed flow. Admin-only —
      // contains nothing sensitive, but only admins can run the seed
      // and seeing this doc makes no sense for staff.
      match /data/seedState {
        allow read, write: if isTenantAdmin(tenantId);
      }
      // Integrity scanner report. Read: tenant admin (UI badge). Write:
      // server-side only (the runIntegrityScan cron runs as admin SDK
      // which bypasses rules). Clients are denied write so a compromised
      // admin can't fake a green badge.
      match /data/integrityReport {
        allow read:  if isTenantAdmin(tenantId);
        allow write: if false;
      }
      // Billing artefacts written by the Stripe webhook. Read: tenant
      // admin (Plan & Billing UI lists open disputes + refund history).
      // Write: server-only — the stripeWebhook handler writes via admin
      // SDK after verifying the Stripe signature. Clients are denied
      // write so a compromised admin can't fabricate a "won" dispute
      // outcome or a fake refund record. Membership-nested refunds use
      // their own rule below.
      match /disputes/{disputeId} {
        allow read:  if isTenantAdmin(tenantId);
        allow write: if false;
      }
      match /refunds/{refundId} {
        allow read:  if isTenantAdmin(tenantId);
        allow write: if false;
      }
      // SMS / TFN provisioning state. Read: tenant admin (status UI).
      // Write: server-only — the provisionTenantSMS / twilioStatusWebhook
      // Cloud Functions update this via admin SDK. Holds the form data
      // the tenant submitted, the Twilio TrustHub SIDs, and the current
      // verification status. No raw credentials live here.
      match /data/sms {
        allow read:  if isTenantAdmin(tenantId);
        allow write: if false;
      }
      // Onboarding wizard state — which phase the tenant is on,
      // completion timestamps, per-phase status. Read: tenant admin
      // (the wizard reads to know where to resume). Write: server-only
      // via markOnboardingPhase Cloud Function so side effects fire.
      match /data/onboarding {
        allow read:  if isTenantAdmin(tenantId);
        allow write: if false;
      }
      // Multi-location config. Read + write: tenant admin. Basic
      // shape enforcement via security rules — `list` is an array,
      // `defaultLocationId` is a string. Per-location field shape isn't
      // enforced at the rules layer (admin SDK Cloud Functions could
      // add it later if abuse appears).
      match /data/locations {
        allow read:  if isTenantAdmin(tenantId);
        allow write: if isTenantAdmin(tenantId)
          && request.resource.data.keys().hasAny(['list', 'defaultLocationId'])
          && (
            !request.resource.data.keys().hasAll(['list']) ||
            request.resource.data.list is list
          );
      }

      // Handbook signatures — each user reads/writes their own; admin reads all
      match /handbookSigs/{userId} {
        allow read:  if isAuthenticated() && (isTenantAdmin(tenantId) || request.auth.uid == userId);
        allow write: if isAuthenticated() && request.auth.uid == userId;
      }

      // Services sub-collection: publicly readable
      match /services/{serviceId} {
        allow read:  if true;
        allow write: if isTenantAdmin(tenantId);
      }

      // Clients: only this tenant's staff can read/write
      match /clients/{clientId} {
        allow read, write: if isTenantStaff(tenantId);
      }

      // Employees.
      // Parent doc: public read (booking page needs name/photo/services/social).
      // Private comp sub-doc: admin-only — holds taxId (SSN), payRate,
      // commissionPct, hourlyRate, paymentPref, paymentNotes (banking
      // info), gustoId, gustoEmail. Without this split the parent doc
      // (publicly readable for the booking flow) was leaking SSNs to
      // anyone on the internet.
      match /employees/{employeeId} {
        allow read:  if true;
        allow write: if isTenantAdmin(tenantId);
        match /private/{docId} {
          allow read, write: if isTenantAdmin(tenantId);
        }
      }

      // Appointments.
      // Reads are tenant-staff only — appointments hold full client PII
      // (name, phone, email, notes incl. allergies). Public surfaces that
      // need busy-slot info (booking page) or single-appt info (check-in)
      // go through the `getPublicAvailability` / `getPublicAppointment`
      // Cloud Function callables, which return a minimum slice with no PII.
      // Public create stays — online booking writes a new appt directly,
      // with length caps so the public payload can't be abused as a
      // XSS / oversized-payload sink. Public single-field check-in update
      // also stays so the booking confirmation link works without auth.
      match /appointments/{apptId} {
        allow read:           if isTenantStaff(tenantId);
        // Create is STAFF-ONLY. Public online bookings no longer write here
        // directly — they go through the submitOnlineBooking Cloud Function,
        // which re-runs the banned / cancellation / booking-card / honeypot
        // gates and writes via the Admin SDK (which bypasses these rules). This
        // makes those gates a hard server boundary instead of a workflow guard.
        // (A view-only tech is staff but lacks canEditSchedule, so they're
        // denied here too.)
        allow create:         if canEditSchedule(tenantId);
        allow delete:         if canEditSchedule(tenantId);
        // Public update is single-shot only: a check-in can fire at most
        // once per appointment. Without this, a public caller (knowing
        // the apptId) can flap `checkedInAt` null↔value repeatedly to
        // re-trigger the `notifyOnCheckIn` Firestore trigger and email-
        // bomb the assigned tech via the salon's verified Resend domain.
        // Staff writes require schedule-edit permission (view-only techs
        // are blocked); the public check-in branch stays open for the
        // booking-confirmation link.
        allow update:         if canEditSchedule(tenantId) || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['checkedInAt'])
          && resource.data.get('checkedInAt', null) == null
          && request.resource.data.checkedInAt is string
        );
      }

      // Time off (vacation/sick/personal): staff read so the day grid can
      // render block-out overlays; staff write so techs can self-manage and
      // admins/schedulers can manage anyone.
      match /timeOff/{timeOffId} {
        allow read:  if isTenantStaff(tenantId);
        allow write: if isTenantStaff(tenantId);
      }

      // Membership plans (templates): public read so client-portal can browse
      // available plans; admin write only.
      match /membershipPlans/{planId} {
        allow read:  if true;
        allow write: if isTenantAdmin(tenantId);
      }
      // Memberships (per-client subscriptions): staff read for checkout +
      // admin write to assign/cancel.
      match /memberships/{membershipId} {
        allow read:  if isTenantStaff(tenantId);
        allow write: if isTenantAdmin(tenantId);
        // Per-membership refund history (written by stripeWebhook on
        // charge.refunded for membership subscriptions). Read: tenant
        // admin. Write: server-only.
        match /refunds/{refundId} {
          allow read:  if isTenantAdmin(tenantId);
          allow write: if false;
        }
      }

      // Logs: any authenticated user can create, only admin can read
      match /logs/{logId} {
        allow create: if isAuthenticated();
        allow read:   if isTenantAdmin(tenantId);
      }

      // Notifications — staff create; check-in page can also create the
      // 'client_checkin' type unauthenticated. Admin manages reads/updates.
      match /notifications/{notifId} {
        allow create: if isTenantStaff(tenantId) ||
                         request.resource.data.get('changeType', '') == 'client_checkin';
        allow read, update, delete: if isTenantAdmin(tenantId);
      }

      // Access requests — any signed-in user can write their own (keyed by uid)
      match /requests/{userId} {
        allow create, update: if isAuthenticated() && request.auth.uid == userId;
        allow read, delete:   if isTenantAdmin(tenantId);
      }

      // Mobile push tokens — keyed by uid, contain Expo push tokens used
      // by sendApptNotification's push fan-out. Each user can read/write
      // ONLY their own doc (so they can register a token from their own
      // device). The Cloud Function uses Admin SDK and bypasses rules,
      // so it can read across users for fan-out. Tokens are not secrets
      // but they let anyone who learns one send arbitrary push to that
      // device, so we still gate at the user-uid layer.
      match /userPushTokens/{uid} {
        allow read, write: if isAuthenticated() && request.auth.uid == uid;
      }

      // Internal meetings.
      // Public meetings: any tenant staff can read.
      // Private meetings (1:1s, performance reviews, anything flagged
      // `private: true`) restrict reads to: the organizer (createdBy
      // matches the caller's email), tenant admins, or listed participants.
      // Participants are checked against a `participantEmails` list (the
      // app maintains it on every save) because Firestore rules can't
      // iterate over the structured `participants` array.
      // Legacy meetings without `participantEmails` default to admin-only
      // when private — safe fallback if the projection is missing.
      match /meetings/{meetingId} {
        allow read: if isTenantStaff(tenantId) && (
          resource.data.private != true
          || isTenantAdmin(tenantId)
          || (resource.data.createdBy is string && resource.data.createdBy == request.auth.token.email.lower())
          || (resource.data.participantEmails is list && request.auth.token.email.lower() in resource.data.participantEmails)
        );
        allow write: if isTenantAdmin(tenantId);
      }

      // Bonuses: admin only
      match /bonuses/{bonusId} {
        allow read, create, delete: if isTenantAdmin(tenantId);
      }

      // Payroll runs: admin only
      match /payrollRuns/{runId} {
        allow read, write: if isTenantAdmin(tenantId);
      }

      // Gift cards: staff can read (so checkout can validate balance);
      // admin can write (mint, redeem-server-side, top-up). Without the
      // admin gate on writes, a tech could open the JS console and
      // self-issue an arbitrary balance.
      match /giftCards/{cardId} {
        allow read:  if isTenantStaff(tenantId);
        allow write: if isTenantAdmin(tenantId);
      }

      // Promo codes: staff can read (checkout validates code); only admin
      // can write (create / disable / change percent). Otherwise a tech
      // could mint a 100%-off, unlimited-use code from the console.
      match /promoCodes/{promoId} {
        allow read:  if isTenantStaff(tenantId);
        allow write: if isTenantAdmin(tenantId);
      }

      // Feedback (bugs/ideas): any authenticated user can create; admin reads/updates
      match /feedback/{feedbackId} {
        allow create: if isAuthenticated();
        allow read, update: if isTenantAdmin(tenantId);
      }

      // Performance reviews: admin only
      match /reviews/{reviewId} {
        allow read, write: if isTenantAdmin(tenantId);
      }

      // User preferences (tech overlay, etc.): each user owns their own doc
      match /userPrefs/{userId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }

      // Retail products: staff can read (POS checkout needs the catalog);
      // admin can do everything else. Stock-only updates by non-admin
      // staff during checkout are permitted via a narrow diff allowlist.
      match /products/{productId} {
        allow read:   if isTenantStaff(tenantId);
        allow create, delete: if isTenantAdmin(tenantId);
        allow update: if isTenantAdmin(tenantId)
          || (isTenantStaff(tenantId)
              && request.resource.data.diff(resource.data).affectedKeys()
                   .hasOnly(['stock', 'updatedAt', 'lastSoldAt']));
      }

      // Receipts (post-checkout outreach): staff create — this triggers an
      // email from the salon's verified domain via sendReceiptEmail, so the
      // create gate must be tenant-scoped to prevent phishing through it.
      // Admin reads/manages; Cloud Function updates via admin SDK.
      match /receipts/{receiptId} {
        allow create:               if isTenantStaff(tenantId);
        allow read, update, delete: if isTenantAdmin(tenantId);
      }

      // Idempotency markers for a sale's non-idempotent side effects (keyed by
      // saleId). Staff claim one per checkout so an offline-queue replay can't
      // double-apply store credit / gift-card debits / stock. No sensitive data
      // — just an existence flag + timestamp.
      match /saleMarkers/{saleId} {
        allow read, write: if isTenantStaff(tenantId);
      }

      // Marketing campaigns: admin creates/reads; Cloud Function updates status via admin SDK
      match /campaigns/{campaignId} {
        allow read, write: if isTenantAdmin(tenantId);
      }

      // Blocked booking attempts (honeypot / bot signals). Written server-only by
      // findOrCreateClient via the Admin SDK; staff read them in the
      // Cancellations & No-Shows report. No client writes.
      match /fraudBlocks/{blockId} {
        allow read:  if isTenantStaff(tenantId);
        allow write: if false;
      }

      // Anti-abuse rate counters (fsRateAllow). Server-only — Admin SDK reads +
      // increments them; no client access. Purged nightly by purgeOldTombstones.
      match /rateCounters/{counterId} {
        allow read, write: if false;
      }

      // Client chat threads. Chat docs are keyed by clientId and store the
      // client's email in `clientEmail`. Staff get full access; the portal
      // client whose email matches owns the chat.
      match /chats/{chatId} {
        allow read:   if isTenantStaff(tenantId) ||
                         (isAuthenticated() && resource.data.clientEmail == request.auth.token.email);
        allow create: if isTenantStaff(tenantId) ||
                         (isAuthenticated() &&
                          request.resource.data.clientEmail == request.auth.token.email);
        allow update: if isTenantStaff(tenantId) ||
                         (isAuthenticated() &&
                          resource.data.clientEmail == request.auth.token.email &&
                          request.resource.data.clientEmail == request.auth.token.email);
        allow delete: if isTenantStaff(tenantId);
      }

      // Review requests: staff create only — this triggers an email from
      // the salon's verified domain via sendReviewRequestEmail.
      match /reviewRequests/{reqId} {
        allow create:               if isTenantStaff(tenantId);
        allow read, update, delete: if isTenantAdmin(tenantId);
      }

      // Chat notifications: staff create OR a portal client creating a
      // notification matching their own email. Cloud Function reads via admin SDK.
      match /chatNotifications/{notifId} {
        allow create: if isTenantStaff(tenantId) ||
                         (isAuthenticated() &&
                          request.resource.data.clientEmail == request.auth.token.email);
        allow read, update, delete: if isTenantAdmin(tenantId);
      }

      // Review received records: tenant staff create; admin manages
      match /reviewReceived/{docId} {
        allow create:               if isTenantStaff(tenantId);
        allow read, update, delete: if isTenantAdmin(tenantId);
      }

      // Sandbox SMS log — every fake outbound SMS gets a row here when
      // the tenant is in sandbox mode. Inspectable by tenant admins via
      // the Marketing → SMS Test Mode panel. Server-only writes (the
      // Cloud Functions that handle each send path). Admins can delete
      // (purge the log) but not create or update — append-only.
      match /sandboxSmsLog/{logId} {
        allow read, delete: if isTenantAdmin(tenantId);
        allow write:        if false;
      }

      // ── Per-tenant cost/usage logs ──────────────────────
      // Three raw collections (usageSms, usageEmail, usageAi) are written
      // server-side by lib/usage.js after each paid outbound call. Two
      // rollup collections (usageDaily, usageMonthly) are written by the
      // nightly aggregator cron. All five are admin-only because cost
      // figures are sensitive business intel; rollup docs are also fetched
      // by the platform-admin UI (which signs in with a platform admin
      // email, satisfying isBootstrapAdmin / isPlatformAdmin).
      // Raw event collections hold the masked recipient (last-4 phone /
      // local-prefix email) which is a weak per-customer signal — tenant
      // admins only, never the platform admin.
      match /usageSms/{logId} {
        allow read:  if isTenantAdmin(tenantId);
        allow write: if false;
      }
      match /usageEmail/{logId} {
        allow read:  if isTenantAdmin(tenantId);
        allow write: if false;
      }
      match /usageAi/{logId} {
        allow read:  if isTenantAdmin(tenantId);
        allow write: if false;
      }
      // Rollups hold pure aggregate numbers — no recipient signal at all
      // — so the platform admin can read them for the cross-tenant cost
      // dashboard without violating principle #10 (no customer-data
      // read access by the platform team).
      match /usageDaily/{dayKey} {
        allow read:  if isTenantAdmin(tenantId) || isPlatformAdmin();
        allow write: if false;
      }
      match /usageMonthly/{monthKey} {
        allow read:  if isTenantAdmin(tenantId) || isPlatformAdmin();
        allow write: if false;
      }

      // Per-tenant email suppression list. Populated by sesEventWebhook
      // when SES reports a bounce or complaint for one of this tenant's
      // sends. Mirrors SES Tenants' per-tenant suppression scope: a
      // bounce on Salon A's send only blocks Salon A's future sends to
      // that address, not Salon B's. Tenant admins can read (for the
      // Marketing tab's suppression-list view) and delete (to manually
      // un-suppress after the recipient confirms their address is
      // working). Writes are server-only.
      match /suppression/{hash} {
        allow read, delete: if isTenantAdmin(tenantId);
        allow write:        if false;
      }

      // Campaign templates: admin only
      match /campaignTemplates/{tplId} {
        allow read, write: if isTenantAdmin(tenantId);
      }

      // Automation dedup records: admin reads; Cloud Functions write via admin SDK
      match /automationSent/{docId} {
        allow read, write: if isTenantAdmin(tenantId);
      }

      // Walk-in / arrival queue: public read+create (kiosk); staff update/delete
      match /waitlist/{entryId} {
        allow read, create: if true;
        allow update, delete: if isTenantStaff(tenantId);
      }

      // Walk-in turn rotation roster (one doc per day) — only this tenant's
      // staff so the front desk can clock techs in/out and rotate them.
      match /turnRoster/{date} {
        allow read, write: if isTenantStaff(tenantId);
      }

      // Attendance / time cards (one doc per day). Admin-only — the React
      // UI already restricts AttendanceAdmin to admins, but rules must
      // match: a tech reading attendance from the console would expose
      // every coworker's clock-in/clock-out times across every day.
      match /attendance/{date} {
        allow read, write: if isTenantAdmin(tenantId);
      }

      // AI assistant audit log — every write tool the in-app chatbot
      // calls drops a record here. Owner reads to inspect; platform
      // admin reads for support / forensics; nobody writes from a
      // client (Cloud Function admin SDK only).
      match /aiActions/{actionId} {
        allow read:  if isTenantAdmin(tenantId) || isPlatformAdmin();
        allow write: if false;
      }

      // Server-only state for the chatWithSalonAdmin tool-use loop.
      // aiPendingConfirms holds destructive-tool confirmation records
      // (5-min TTL); aiSessions holds per-session tool-call counters
      // (1h sliding TTL). Cleaned by the daily purgeExpiredAiSessions
      // cron. Clients never read or write these — leaking the records
      // would expose nothing sensitive (hash keys + intent strings)
      // but there's also no reason for a client to need them.
      match /aiPendingConfirms/{hashKey} {
        allow read, write: if false;
      }
      match /aiSessions/{sessionId} {
        allow read, write: if false;
      }

      // Support tickets: tenant admin reads/creates within their tenant;
      // platform admin can read/update (for triage + status / reply). All
      // writes go through Cloud Functions (admin SDK bypasses rules); the
      // allow-rules here only gate the rare direct-client reads.
      match /supportTickets/{ticketId} {
        allow read:  if isTenantAdmin(tenantId) || isPlatformAdmin();
        allow write: if false;

        match /replies/{replyId} {
          allow read:  if isTenantAdmin(tenantId) || isPlatformAdmin();
          allow write: if false;
        }
      }

      // Tax forms (1099-NEC): admin manages all; tenant staff with the
      // matching email read their own. The tenant-scoped check prevents
      // a tech with a duplicate email at another salon from leaking forms.
      match /taxForms/{formId} {
        allow read:                if isTenantAdmin(tenantId) ||
                                      (isTenantStaff(tenantId) &&
                                       request.auth.token.email == resource.data.techEmail);
        allow create, update, delete: if isTenantAdmin(tenantId);
      }
    }

    // Plume Nexus marketing-site inquiries. Only the cloud function (admin
    // SDK, bypasses rules) writes; only the bootstrap admin reads.
    match /plumenexus_inquiries/{inquiryId} {
      allow read:  if isBootstrapAdmin();
      allow write: if false;
    }

    // ── Platform admin (internal-only) ─────────────────────
    // Authoritative platform-admin email allowlist. Bootstrap admin manages.
    // Platform admin app reads it on every sign-in.
    function isPlatformAdmin() {
      return isBootstrapAdmin() || (
        isAuthenticated() &&
        request.auth.token.email is string &&
        request.auth.token.email.lower() in
          get(/databases/$(database)/documents/platform/admins).data.get('emails', [])
      );
    }

    match /platform/admins {
      allow read:  if isAuthenticated();
      allow write: if isBootstrapAdmin();
    }

    // Audit log — append-only by platform admins. Read only by platform admins.
    // No deletes, no updates — immutable history. Uses subcollection so we can
    // shard if it grows huge.
    match /platform/audit_log/entries/{entryId} {
      allow read:   if isPlatformAdmin();
      allow create: if isPlatformAdmin() &&
                       request.resource.data.actor == request.auth.token.email;
      allow update, delete: if false;
    }

    // Platform-wide cost & usage rollups. Written by the nightly
    // aggregator cron (admin SDK, bypasses rules). Read by the
    // platform-admin UI to render the cross-tenant cost graph.
    match /platform/usage/daily/{dayKey} {
      allow read:  if isPlatformAdmin();
      allow write: if false;
    }
    match /platform/usage/monthly/{monthKey} {
      allow read:  if isPlatformAdmin();
      allow write: if false;
    }
    match /platform/gcpCost/daily/{dayKey} {
      allow read:  if isPlatformAdmin();
      allow write: if false;
    }

    // Other future platform/* docs (settings, feature flags, etc.) — admin-only.
    match /platform/{docId} {
      allow read, write: if isBootstrapAdmin();
    }
  }
}
