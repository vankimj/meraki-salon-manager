rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isBootstrapAdmin() {
      return request.auth != null &&
             request.auth.token.email in ['jvankim@gmail.com'];
    }
    function isAuthenticated() {
      return request.auth != null;
    }
    // Tenant owner: email matches the ownerEmail stored in the root tenant registry doc.
    // Used so a non-bootstrap admin can manage their own tenant's data.
    function isTenantOwner(tenantId) {
      return isAuthenticated() &&
        request.auth.token.email ==
          get(/databases/$(database)/documents/tenants/$(tenantId)).data.ownerEmail;
    }
    function isTenantAdmin(tenantId) {
      return isBootstrapAdmin() || isTenantOwner(tenantId);
    }

    // ── Legacy path (read-only for migration) ────────────
    match /salon/{document} {
      allow read: if true;
      allow write: if isBootstrapAdmin();
    }
    match /logs/{logId} {
      allow read:   if isBootstrapAdmin();
      allow create: if isAuthenticated();
    }

    // ── Tenant data ──────────────────────────────────────
    match /tenants/{tenantId} {
      // Root tenant registry document (plan, owner, name) — super-admin only
      allow read, write: if isBootstrapAdmin();


      // Config documents live in a data/ sub-collection (4-segment paths = valid Firestore docs)
      match /data/slides {
        allow read:  if true;
        allow write: if isTenantAdmin(tenantId);
      }
      match /data/users {
        allow read:  if isAuthenticated();
        allow write: if isTenantAdmin(tenantId);
      }
      match /data/settings {
        allow read:  if isAuthenticated();
        allow write: if isTenantAdmin(tenantId);
      }
      match /data/handbook {
        allow read:  if isAuthenticated();
        allow write: if isTenantAdmin(tenantId);
      }
      match /data/bookingConfig {
        allow read:  if true;
        allow write: if isTenantAdmin(tenantId);
      }
      match /data/webfront {
        allow read:  if true;
        allow write: if isTenantAdmin(tenantId);
      }
      match /data/googleReviews {
        allow read:  if true;
        allow write: if isTenantAdmin(tenantId);
      }

      // Handbook signatures — each user reads/writes their own; admin reads all
      match /handbookSigs/{userId} {
        allow read:  if isAuthenticated() && (isTenantAdmin(tenantId) || request.auth.uid == userId);
        allow write: if isAuthenticated() && request.auth.uid == userId;
      }

      // Services sub-collection: publicly readable
      match /services/{serviceId} {
        allow read:  if true;
        allow write: if isTenantAdmin(tenantId);
      }

      // Clients: any authenticated staff can read/write
      match /clients/{clientId} {
        allow read:  if isAuthenticated();
        allow write: if isAuthenticated();
      }

      // Employees: public read (names/photos shown on booking page); only admin can write
      match /employees/{employeeId} {
        allow read:  if true;
        allow write: if isTenantAdmin(tenantId);
      }

      // Appointments: public read (check-in) + public create (online booking); staff full access
      match /appointments/{apptId} {
        allow read:           if true;
        allow create:         if true;
        allow delete:         if isAuthenticated();
        allow update:         if isAuthenticated() ||
                                 request.resource.data.diff(resource.data).affectedKeys().hasOnly(['checkedInAt']);
      }

      // Logs: any authenticated user can create, only admin can read
      match /logs/{logId} {
        allow create: if isAuthenticated();
        allow read:   if isTenantAdmin(tenantId);
      }

      // Notifications — authenticated users can create; check-in page can create client_checkin type; admin manages
      match /notifications/{notifId} {
        allow create: if isAuthenticated() ||
                         request.resource.data.get('changeType', '') == 'client_checkin';
        allow read, update, delete: if isTenantAdmin(tenantId);
      }

      // Access requests — any signed-in user can write their own (keyed by uid)
      match /requests/{userId} {
        allow create, update: if isAuthenticated() && request.auth.uid == userId;
        allow read, delete:   if isTenantAdmin(tenantId);
      }

      // Internal meetings: admin writes, any authenticated staff can read
      match /meetings/{meetingId} {
        allow read:  if isAuthenticated();
        allow write: if isTenantAdmin(tenantId);
      }

      // Bonuses: admin only
      match /bonuses/{bonusId} {
        allow read, create, delete: if isTenantAdmin(tenantId);
      }

      // Payroll runs: admin only
      match /payrollRuns/{runId} {
        allow read, write: if isTenantAdmin(tenantId);
      }

      // Gift cards: any authenticated staff can read/write
      match /giftCards/{cardId} {
        allow read, write: if isAuthenticated();
      }

      // Promo codes: any authenticated staff can read/write
      match /promoCodes/{promoId} {
        allow read, write: if isAuthenticated();
      }

      // Feedback (bugs/ideas): any authenticated user can create; admin can read/update
      match /feedback/{feedbackId} {
        allow create: if isAuthenticated();
        allow read, update: if isTenantAdmin(tenantId);
      }

      // Performance reviews: admin only
      match /reviews/{reviewId} {
        allow read, write: if isTenantAdmin(tenantId);
      }

      // User preferences (tech overlay, etc.): each user owns their own doc
      match /userPrefs/{userId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }

      // Retail products: staff can read; authenticated users can write (stock decrements happen at checkout)
      match /products/{productId} {
        allow read:  if isAuthenticated();
        allow write: if isAuthenticated();
      }

      // Receipts (post-checkout outreach): staff create; admin reads/manages; Cloud Function updates via admin SDK
      match /receipts/{receiptId} {
        allow create:              if isAuthenticated();
        allow read, update, delete: if isTenantAdmin(tenantId);
      }

      // Marketing campaigns: admin creates/reads; Cloud Function updates status via admin SDK
      match /campaigns/{campaignId} {
        allow read, write: if isTenantAdmin(tenantId);
      }

      // Client chat threads: any authenticated user (staff or portal client) can read/write
      match /chats/{chatId} {
        allow read, write: if isAuthenticated();
      }

      // Review requests: staff create; admin reads/manages; Cloud Function updates via admin SDK
      match /reviewRequests/{reqId} {
        allow create:               if isAuthenticated();
        allow read, update, delete: if isTenantAdmin(tenantId);
      }

      // Chat notifications: any authenticated user can create (portal clients + staff); Cloud Function reads via admin SDK
      match /chatNotifications/{notifId} {
        allow create: if isAuthenticated();
        allow read, update, delete: if isTenantAdmin(tenantId);
      }

      // Review received records: authenticated staff create; Cloud Function reads via admin SDK; admin manages
      match /reviewReceived/{docId} {
        allow create:               if isAuthenticated();
        allow read, update, delete: if isTenantAdmin(tenantId);
      }

      // Campaign templates: admin only
      match /campaignTemplates/{tplId} {
        allow read, write: if isTenantAdmin(tenantId);
      }

      // Automation dedup records: admin reads; Cloud Functions write via admin SDK
      match /automationSent/{docId} {
        allow read, write: if isTenantAdmin(tenantId);
      }

      // Walk-in / arrival queue: public read+create (kiosk); staff update/delete
      match /waitlist/{entryId} {
        allow read, create: if true;
        allow update, delete: if isAuthenticated();
      }

      // Walk-in turn rotation roster (one doc per day) — any authenticated
      // staff can read & write so anyone at the front desk can clock techs
      // in/out and rotate them as walk-ins are assigned.
      match /turnRoster/{date} {
        allow read, write: if isAuthenticated();
      }

      // Attendance / time cards (one doc per day) — staff can read; only
      // admin can edit clock-in / clock-out times.
      match /attendance/{date} {
        allow read:  if isAuthenticated();
        allow write: if isTenantAdmin(tenantId);
      }

      // Tax forms (1099-NEC): admin manages all; authenticated users read their own (matched by email)
      match /taxForms/{formId} {
        allow read:                if isTenantAdmin(tenantId) ||
                                      (isAuthenticated() && request.auth.token.email == resource.data.techEmail);
        allow create, update, delete: if isTenantAdmin(tenantId);
      }
    }
  }
}
