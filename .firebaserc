{
  "projects": {
    "default":   "plumenexus-prod",
    "legacy":    "meraki-salon-manager",
    "marketing": "plumenexus-marketing"
  },
  "targets": {
    "plumenexus-prod": {
      "hosting": {
        "app":            ["plumenexus-prod"],
        "platform-admin": ["plumenexus-admin"]
      }
    },
    "plumenexus-marketing": {
      "hosting": {
        "plumenexus": ["plumenexus-marketing"]
      }
    },
    "meraki-salon-manager": {
      "hosting": {
        "app":            ["meraki-salon-manager"],
        "plumenexus":     ["plumenexus"],
        "platform-admin": ["plumenexus-admin"]
      }
    }
  }
}
